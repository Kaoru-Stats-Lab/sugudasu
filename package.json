{
  "name": "sugudasu",
  "private": true,
  "description": "SUGUDASU — 無料ビジネスツール8選（静的サイト）",
  "scripts": {
    "build:pages": "node scripts/verify-tool-naming.mjs && node scripts/verify-changelog.mjs && node scripts/verify-statements-product.mjs && node scripts/sync-readme-tools-table.mjs --check && node scripts/verify-ogp.mjs && node scripts/build-pages.mjs && node scripts/verify-pages-free-plan.mjs",
    "build:pages:sync": "node scripts/build-pages.mjs --target=sync && node scripts/verify-pages-free-plan.mjs",
    "deploy:pages:sync": "npm run release:pages:sync && npx wrangler pages deploy dist-sync --project-name=sugudasu-sync --branch=main",
    "deploy:gate": "node scripts/check-deploy-gate.mjs",
    "deploy:gate:core": "node scripts/check-deploy-gate.mjs --target=core",
    "deploy:gate:sync": "node scripts/check-deploy-gate.mjs --target=sync",
    "keepalive:supabase-sync": "node scripts/supabase-sync-keepalive.mjs",
    "preview:pages:sync": "npm run build:pages:sync && npx --yes serve dist-sync -l 8081",
    "generate:tool-facts": "node scripts/generate-tool-facts.mjs",
    "scaffold:tool-facts": "node scripts/scaffold-tool-facts.mjs",
    "generate:lp-matrix": "node scripts/generate-lp-marketing-matrix.mjs",
    "generate:marketing-context": "node scripts/generate-marketing-context.mjs",
    "sync:readme-tools": "node scripts/sync-readme-tools-table.mjs",
    "validate:readme-tools": "node scripts/sync-readme-tools-table.mjs --check",
    "validate:tool-naming": "node scripts/verify-tool-naming.mjs",
    "validate:changelog": "node scripts/verify-changelog.mjs",
    "validate:ogp": "node scripts/verify-ogp.mjs",
    "validate:statements-product": "node scripts/verify-statements-product.mjs",
    "sync:statements-product-date": "node scripts/verify-statements-product.mjs --sync-date",
    "sync:statements-product-names": "node scripts/sync-statements-product-names.mjs",
    "validate:adsense": "node scripts/verify-adsense-pages.mjs",
    "generate:favicons": "node scripts/generate-favicons.mjs",
    "guard:pages-free": "node scripts/verify-pages-free-plan.mjs",
    "guard:pages-budget": "node scripts/guard-pages-build-budget.mjs check",
    "guard:pages-budget:show": "node scripts/guard-pages-build-budget.mjs show",
    "release:pages:free": "npm run deploy:gate:core && npm run build:pages && npm run guard:pages-budget && node scripts/guard-pages-build-budget.mjs consume --project=core",
    "release:pages:sync": "npm run deploy:gate:sync && npm run build:pages:sync && npm run guard:pages-budget && node scripts/guard-pages-build-budget.mjs consume --project=sync",
    "generate:font-styles-math": "node scripts/generate-font-styles-math.mjs",
    "preview:pages": "npm run build:pages && npx --yes serve dist -l 8080",
    "export:x-posts-tsv": "node scripts/export-x-posts-calendar-tsv.mjs",
    "test:all": "npm run test:prize-law && npm run test:normalize && npm run test:webp-to-jpg && npm run test:video-frame && npm run test:mask && npm run test:watermark && npm run test:pdf-images && npm run test:test-data && npm run test:group-split && npm run test:timeline && npm run test:linkify && npm run test:link-qr && npm run test:csv-import && npm run test:table-conv && npm run test:invoice-finance && npm run test:sticky-room",
    "test:link-qr": "node scripts/link-qr-engine.test.mjs",
    "test:csv-import": "node scripts/sg-csv-import.test.mjs",
    "test:table-conv": "node scripts/table-conv.test.mjs",
    "test:invoice-finance": "node scripts/invoice-finance.test.mjs",
    "test:prize-law": "node scripts/prize-law-eval.test.mjs",
    "test:lottery": "node scripts/prize-law-eval.test.mjs",
    "test:normalize": "node scripts/text-normalize.test.mjs",
    "test:webp-to-jpg": "node scripts/webp-to-jpg.test.mjs",
    "test:video-frame": "node scripts/video-frame.test.mjs",
    "test:mask": "node scripts/mask-engine.test.mjs",
    "test:watermark": "node scripts/watermark-engine.test.mjs",
    "test:pdf-images": "node scripts/pdf-images-engine.test.mjs",
    "test:test-data": "node scripts/test-data-engine.test.mjs",
    "test:group-split": "node scripts/group-split.test.mjs",
    "test:group-split-assign": "node scripts/group-split-assign.test.mjs",
    "test:planning-poker": "node scripts/planning-poker-engine.test.mjs",
    "test:timeline": "node scripts/timeline-engine.test.mjs",
    "test:linkify": "node scripts/sg-linkify.test.mjs",
    "test:sticky-room": "node scripts/sticky-room-sync.test.mjs && node scripts/sticky-room-crypto.test.mjs && node scripts/sticky-room-lww-conflict.test.mjs && node scripts/sticky-room-longevity.test.mjs",
    "test:sticky-room:lww": "node scripts/sticky-room-lww-conflict.test.mjs",
    "test:sticky-room:longevity": "node scripts/sticky-room-longevity.test.mjs",
    "longevity:sticky-room": "node scripts/sticky-room-longevity-e2e.mjs",
    "test:sticky-room-crypto": "node scripts/sticky-room-crypto.test.mjs",
    "verify:sticky-room:phase2-dod": "node scripts/sticky-room-phase2-dod.mjs",
    "verify:sticky-room:no-store": "node scripts/sticky-room-no-store.test.mjs",
    "stress:sticky-room": "node scripts/sticky-room-stress.mjs",
    "poc:schedule-gantt": "npx --yes serve . -l 8090",
    "poc:schedule-split-pane": "npx --yes serve . -l 8092"
  },
  "devDependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^2.0.1",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^2.0.0",
    "@tailwindcss/cli": "^4.3.1",
    "frappe-gantt": "^1.2.2",
    "playwright": "^1.49.1",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.3.1"
  },
  "dependencies": {
    "pdfjs-dist": "^5.4.296"
  }
}
